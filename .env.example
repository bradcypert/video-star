# Copy this file to ~/.video-star/.env and fill in your values.
# This file should NEVER be committed to git.

# Required: get your key at https://console.deepgram.com/
DEEPGRAM_API_KEY=

# Optional: used for AI-generated YouTube descriptions (GPT-4o)
# Leave blank to use template-based description generation
OPENAI_API_KEY=

# Directory where output folders are created
OUTPUT_DIR=~/Videos/video-star-output

# Path to ffmpeg binary. Leave blank to auto-detect from PATH.
FFMPEG_PATH=

# Number of thumbnail candidates to extract
THUMBNAIL_COUNT=5

# Add text overlay to extracted thumbnail frames (requires Pillow)
USE_THUMBNAIL_OVERLAY=false
